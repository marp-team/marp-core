{
  "name": "@marp-team/marp-core",
  "version": "4.3.0",
  "description": "The core of Marp tools",
  "license": "MIT",
  "author": {
    "name": "Marp team",
    "url": "https://github.com/marp-team"
  },
  "contributors": [
    {
      "name": "Yuki Hattori",
      "url": "https://github.com/yhatt"
    }
  ],
  "keywords": [
    "marp",
    "markdown",
    "parser",
    "slide",
    "deck",
    "presentation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/marp-team/marp-core"
  },
  "exports": {
    ".": {
      "types": "./lib/marp.d.mts",
      "import": "./lib/marp.mjs",
      "default": "./lib/marp.cjs"
    },
    "./browser": {
      "types": "./lib/browser.d.mts",
      "import": "./lib/browser.mjs",
      "script": "./lib/browser-iife.iife.js",
      "default": "./lib/browser.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib/"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "tsdown",
    "check:audit": "npm audit",
    "check:format": "npm -s run format -- -c",
    "check:ts": "tsc --noEmit",
    "clean": "node -e \"fs.rmSync('lib',{recursive:true,force:true})\"",
    "format": "prettier \"**/*.{css,js,json,md,mjs,scss,ts,yaml,yml}\"",
    "format:write": "npm -s run format -- --write",
    "gen:shiki": "node scripts/generate-shiki-lang-loaders.mjs",
    "lint:js": "eslint --cache",
    "lint:css": "stylelint \"{src,themes}/**/*.{css,scss}\"",
    "prepare": "run-p gen:*",
    "prepack": "npm-run-all gen:* --parallel check:* lint:* test:coverage --parallel build",
    "preversion": "run-p check:* lint:* test:coverage",
    "sandbox": "run-p watch sandbox:watch",
    "sandbox:watch": "node -e \"fs.mkdirSync('lib',{recursive:true})\" && nodemon",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "version": "curl https://raw.githubusercontent.com/marp-team/actions/v1/lib/scripts/version.js | node && git add -A CHANGELOG.md",
    "watch": "tsdown -w --no-clean"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "nodemonConfig": {
    "watch": "./lib",
    "exec": "npx @marp-team/marp-cli@latest -y"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@csstools/postcss-minify": "^2.0.5",
    "@shikijs/transformers": "^4.0.2",
    "@tsconfig/node20": "^20.1.9",
    "@tsconfig/recommended": "^1.0.13",
    "@tsdown/css": "^0.21.4",
    "@twemoji/api": "^17.0.2",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "^8.57.2",
    "autoprefixer": "^10.4.27",
    "cheerio": "^1.2.0",
    "cssnano": "^7.1.3",
    "emoji-regex": "10.6.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.0",
    "github-markdown-css": "5.9.0",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-junit": "^16.0.0",
    "jest-plugin-context": "^2.9.0",
    "markdown-it": "^14.1.1",
    "markdown-it-emoji": "^3.0.0",
    "nodemon": "^3.1.14",
    "npm-check-updates": "^19.6.3",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "postcss-import": "^16.1.1",
    "postcss-url": "^10.1.3",
    "prettier": "^3.8.1",
    "sass-embedded": "^1.98.0",
    "self-closing-tags": "^1.0.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ts-jest": "29.4.6",
    "tsdown": "^0.21.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.1"
  },
  "dependencies": {
    "@marp-team/marpit": "^3.2.1",
    "@marp-team/marpit-svg-polyfill": "^2.1.0",
    "katex": "^0.16.38",
    "mathjax-full": "^3.2.2",
    "postcss-selector-parser": "^7.1.1",
    "shiki": "^4.0.2",
    "xss": "^1.0.15"
  },
  "overrides": {
    "postcss-url": {
      "minimatch": "^3.1.5"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
